# Required environment variables — copy this file to .env and fill in real values
# NEVER commit the actual .env file to version control

# Redis authentication password (required — set a strong random value in production)
REDIS_PASSWORD=change_me

# Redis host — use "redis" when running via docker compose
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Internal API URL used by the frontend (use service name inside docker compose)
API_URL=http://api:8000
